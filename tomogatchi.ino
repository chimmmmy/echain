void drawScene1() {
  display.setFullWindow();
  display.firstPage();
  do {
    display.fillScreen(GxEPD_WHITE);
    display.drawBitmap(265, 4,  image_battery_empty_bits,  24, 16, GxEPD_BLACK);
    display.drawBitmap(7,   4,  image_bluetooth_bits,       14, 16, GxEPD_BLACK);
    display.setFont();
    display.setTextColor(GxEPD_BLACK);
    display.setCursor(133, 6);
    display.print("music");
    display.setCursor(33, 48);
    display.print("now playing:");
    display.setCursor(107, 70);
