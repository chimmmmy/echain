void titleWriteCallback(uint16_t conn_handle, BLECharacteristic* chr, uint8_t* data, uint16_t len) {
  memset(songTitle, 0, sizeof(songTitle));
  memcpy(songTitle, data, min((int)len, 63));
  musicUpdated = true;
}

void artistWriteCallback(uint16_t conn_handle, BLECharacteristic* chr, uint8_t* data, uint16_t len) {
  memset(artistName, 0, sizeof(artistName));
  memcpy(artistName, data, min((int)len, 63));
  musicUpdated = true;
}

void albumWriteCallback(uint16_t conn_handle, BLECharacteristic* chr, uint8_t* data, uint16_t len) {
  memset(albumName, 0, sizeof(albumName));
  memcpy(albumName, data, min((int)len, 63));
  musicUpdated = true;
}

