    display.drawBitmap(64,  116, image_arrow_left_bits,     14, 10, GxEPD_BLACK);
  } while (display.nextPage());
}

void setup() {
  pinMode(BUTTON_PIN, INPUT_PULLUP);

  display.init();
  display.setRotation(3);

  // BLE setup
  Bluefruit.begin();
  Bluefruit.setName("Tomogatchi");

  musicService.begin();

  titleChar.setProperties(CHR_PROPS_WRITE | CHR_PROPS_WRITE_WO_RESP);
  titleChar.setPermission(SECMODE_OPEN, SECMODE_OPEN);
  titleChar.setWriteCallback(titleWriteCallback);
  titleChar.begin();

  artistChar.setProperties(CHR_PROPS_WRITE | CHR_PROPS_WRITE_WO_RESP);
  artistChar.setPermission(SECMODE_OPEN, SECMODE_OPEN);
  artistChar.setWriteCallback(artistWriteCallback);
  artistChar.begin();

  albumChar.setProperties(CHR_PROPS_WRITE | CHR_PROPS_WRITE_WO_RESP);
  albumChar.setPermission(SECMODE_OPEN, SECMODE_OPEN);
  albumChar.setWriteCallback(albumWriteCallback);
  albumChar.begin();

  Bluefruit.Advertising.addFlags(BLE_GAP_ADV_FLAGS_LE_ONLY_GENERAL_DISC_MODE);
  Bluefruit.Advertising.addTxPower();
  Bluefruit.Advertising.addService(musicService);
  Bluefruit.Advertising.addName();
  Bluefruit.Advertising.start();

  drawScene0();
}

void loop() {
  bool buttonState = digitalRead(BUTTON_PIN);
  if (buttonState == LOW && lastButtonState == HIGH) {
    delay(50);
    currentScene = (currentScene + 1) % 2;
    if (currentScene == 0) drawScene0();
    else drawScene1();
  }
  lastButtonState = buttonState;

  // Redraw music scene if BLE updated song info
  if (musicUpdated && currentScene == 1) {
    musicUpdated = false;
    drawScene1();
  }
}