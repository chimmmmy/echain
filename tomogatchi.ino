    display.setCursor(107, 93);
    display.print(albumName);
    display.drawBitmap(227, 110, image_music_play_bits,     15, 16, GxEPD_BLACK);
    display.drawBitmap(227, 90,  image_music_next_bits,     16, 16, GxEPD_BLACK);
